# ===== Follow-Up microservice configuration =====

# HTTP API port
FOLLOWUP_SERVICE_PORT=3100

# Dedicated Redis (separate from Flowise's Redis)
FOLLOWUP_REDIS_HOST=localhost
FOLLOWUP_REDIS_PORT=6380
# FOLLOWUP_REDIS_URL=redis://localhost:6380
# FOLLOWUP_REDIS_PASSWORD=
# FOLLOWUP_REDIS_USERNAME=

# ClickHouse (log store)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=followup
CLICKHOUSE_LOG_RETENTION_DAYS=30

# Postgres (config storage only — read-once-and-cached, tiny pool)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=flowise
DATABASE_SSL=false
FOLLOWUP_PG_POOL_MAX=4

# Stream / consumer
FOLLOWUP_EVENTS_STREAM=followup:events
FOLLOWUP_CONSUMER_GROUP=followup-workers
FOLLOWUP_STREAM_READ_COUNT=200
FOLLOWUP_STREAM_BLOCK_MS=2000

# Scheduler / worker tuning
FOLLOWUP_POLL_INTERVAL_MS=1000
FOLLOWUP_POLL_BATCH_SIZE=500
FOLLOWUP_WORKER_CONCURRENCY=50
FOLLOWUP_WEBHOOK_TIMEOUT_MS=30000
FOLLOWUP_WEBHOOK_MAX_RETRIES=3

# Session message cache
FOLLOWUP_MAX_CACHED_MESSAGES=50
FOLLOWUP_MSG_CACHE_TTL_SECONDS=86400
FOLLOWUP_CANCEL_FLAG_TTL_SECONDS=300
FOLLOWUP_FIRE_COUNTER_TTL_SECONDS=604800

FOLLOWUP_CONFIG_REFRESH_MS=30000
FOLLOWUP_LOG_LEVEL=info

# P0 resilience
FOLLOWUP_MAX_WEBHOOKS_PER_SECOND=100
FOLLOWUP_CIRCUIT_BREAKER_THRESHOLD=5
FOLLOWUP_CIRCUIT_BREAKER_RESET_MS=60000
FOLLOWUP_AUTO_RESTART_MS=300000

# ===== Main server (packages/server) settings to enable the new path =====
# FOLLOWUP_LEGACY=false        # default; set true to use the old in-process worker
# FOLLOWUP_SERVICE_URL=http://localhost:3100
# FOLLOWUP_REDIS_HOST=localhost
# FOLLOWUP_REDIS_PORT=6380
