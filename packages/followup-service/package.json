{
  "name": "followup-service",
  "version": "1.0.0",
  "description": "Standalone high-scale follow-up microservice (Redis + ClickHouse)",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "nuke": "rimraf dist node_modules .turbo",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec \"ts-node src/index.ts\"",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@clickhouse/client": "^1.4.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/node-fetch": "^2.6.11",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.15.0 <19.0.0 || ^20"
  }
}
